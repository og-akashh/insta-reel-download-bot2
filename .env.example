# Telegram Bot Token
BOT_TOKEN=your_bot_token_here

# Required channels to join (comma-separated: channel_id,invite_link)
REQUIRED_CHANNELS=-100123456789,https://t.me/joinchat/abc; -100987654321,https://t.me/joinchat/xyz
# Or simpler: list of invite links
CHANNEL_1_LINK=https://t.me/your_channel
CHANNEL_2_LINK=https://t.me/another_channel
CHANNEL_1_ID=@your_channel
CHANNEL_2_ID=@another_channel

# Support & owner links
OWNER_LINK=https://t.me/your_username
SUPPORT_CHANNEL_LINK=https://t.me/support_channel

# Download settings
DOWNLOAD_PATH=downloads
MAX_FILE_SIZE_MB=50
MAX_VIDEO_DURATION=300
DELETE_AFTER_MINUTES=20
LOG_LEVEL=INFO
